# ============================================
# Project Z - Production Environment Config
# ============================================
# Copy this file to docker/.env and fill in your values.
# NEVER commit the actual .env file.

# Application
APP_ENV=production
DEBUG=false

# PostgreSQL
POSTGRES_DB=projectz
POSTGRES_USER=projectz
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_HEX_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Organization
ORG_NAME=Your Organization Name
ORG_COUNTRY=Your Country
TIMEZONE=Your/Timezone

# Attendance Engine
DUPLICATE_SCAN_WINDOW_SECONDS=60
DEFAULT_GRACE_PERIOD_MINUTES=15

# Default Admin (first-run seed)
DEFAULT_ADMIN_USERNAME=admin
# Generate: openssl rand -base64 16
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DEFAULT_ADMIN_EMAIL=admin@yourorg.local

# Frontend (used during Docker build)
VITE_API_BASE_URL=https://your-server-domain
VITE_WS_URL=wss://your-server-domain/ws
