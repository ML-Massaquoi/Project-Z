# ============================================
# Project Z - Environment Configuration
# ============================================

# Application
APP_ENV=development
DEBUG=true

# PostgreSQL
POSTGRES_DB=projectz
POSTGRES_USER=projectz
POSTGRES_PASSWORD=projectz_secret

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=projectz-super-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Organization
ORG_NAME=Freetown International Airport
ORG_COUNTRY=Sierra Leone
TIMEZONE=Africa/Freetown

# Attendance Engine
DUPLICATE_SCAN_WINDOW_SECONDS=60
DEFAULT_GRACE_PERIOD_MINUTES=15

# Default Admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=@linux@kali@DYDY21
DEFAULT_ADMIN_EMAIL=admin@projectz.local

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
# For Docker deployment, change to:
# VITE_API_BASE_URL=http://localhost:8081
# VITE_WS_URL=ws://localhost:8081/ws
